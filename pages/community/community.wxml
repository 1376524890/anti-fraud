<!--
社区页面 - 社区模块 (v3)

上游依赖：community.js页面逻辑，community.wxss样式文件
入口：Tab页 /pages/community/community
主要功能：展示帖子流、跳转发帖与帖子详情
输出：渲染社区帖子列表

重要：每当所属的代码发生变化时，必须对相应的文档进行更新操作！
-->
<!--pages/community/community.wxml-->
<view class="community-container">
  <scroll-view scroll-y class="list" bindscrolltolower="loadMore">
    <view wx:if="{{posts.length === 0 && !loading}}" class="empty">
      <text class="empty-icon">📝</text>
      <view class="empty-text">暂无帖子，快来发布第一条吧</view>
    </view>

    <view wx:for="{{posts}}" wx:key="_id" class="post-card" bindtap="goDetail" data-id="{{item._id}}">
      <view class="post-header">
        <image class="avatar" wx:if="{{item.authorAvatarUrl}}" src="{{item.authorAvatarUrl}}" mode="aspectFill" catchtap="goProfile" data-uid="{{item.authorUid}}"></image>
        <view class="avatar placeholder" wx:else catchtap="goProfile" data-uid="{{item.authorUid}}">👤</view>
        <view class="meta">
          <view class="name">{{item.authorNickName || '未设置昵称'}}</view>
          <view class="time">{{item.createdAtText}}</view>
        </view>
      </view>

      <view class="content" wx:if="{{item.content}}">{{item.content}}</view>

      <view class="images" wx:if="{{item.images && item.images.length > 0}}">
        <image wx:for="{{item.images}}" wx:key="*this" class="img" src="{{item}}" mode="aspectFill"></image>
      </view>

      <view class="footer">
        <view class="right-actions">
          <text class="comment-icon">💬</text>
          <text class="comment-count">{{item.commentCount || 0}}</text>
        </view>
      </view>
    </view>

    <view wx:if="{{loading}}" class="loading">加载中...</view>
    <view wx:if="{{!hasMore && posts.length > 0}}" class="no-more">没有更多了</view>
  </scroll-view>

  <!-- 右下角浮动发帖按钮 -->
  <view class="fab-btn" bindtap="goCreate">
    <text class="fab-icon">+</text>
  </view>
</view>
