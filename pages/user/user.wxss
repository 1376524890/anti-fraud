/* pages/user/user.wxss */
.user-container {
  min-height: 100vh;
  background: linear-gradient(180deg, #f0f9ff 0%, #e0f2fe 100%);
}

.user-header {
  position: relative;
  overflow: hidden;
  padding: 48rpx 40rpx 70rpx;
  color: #fff;
  background: linear-gradient(135deg, #0ea5e9 0%, #06b6d4 100%);
}

.user-header::before {
  content: '';
  position: absolute;
  top: -30%;
  right: -15%;
  width: 440rpx;
  height: 440rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.1);
}

/* 头部独立操作区，和资料内容分层 */
.header-topbar {
  position: relative;
  z-index: 2;
  height: 88rpx;
  margin-bottom: 28rpx;
}

.top-right-actions {
  position: absolute;
  top: 0;
  right: 0;
  display: flex;
  align-items: center;
  justify-content: flex-end;
  gap: 16rpx;
}

.notify-entry {
  position: relative;
  width: 80rpx;
  height: 80rpx;
  border-radius: 40rpx;
  background: rgba(255, 255, 255, 0.2);
  display: flex;
  align-items: center;
  justify-content: center;
  backdrop-filter: blur(6rpx);
  flex: 0 0 80rpx;
}

.notify-icon {
  font-size: 36rpx;
  color: #fff;
}

.notify-dot {
  position: absolute;
  top: -6rpx;
  right: -6rpx;
  min-width: 34rpx;
  height: 34rpx;
  padding: 0 8rpx;
  border-radius: 18rpx;
  background: #ef4444;
  display: flex;
  align-items: center;
  justify-content: center;
}

.notify-text {
  color: #fff;
  font-size: 20rpx;
  font-weight: 700;
}

.user-info {
  position: relative;
  z-index: 1;
  display: flex;
  align-items: center;
  justify-content: flex-start;
  margin-bottom: 50rpx;
}

.avatar-wrapper {
  width: 130rpx;
  height: 130rpx;
  padding: 0;
  margin: 0;
  border: none;
  background: transparent;
  display: flex;
  align-items: center;
  justify-content: center;
  flex: 0 0 130rpx;
}

.avatar-wrapper::after {
  border: none;
}

.user-avatar {
  width: 130rpx;
  height: 130rpx;
  border-radius: 50%;
  background: #fff;
  color: #0ea5e9;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 60rpx;
  box-shadow: 0 8rpx 30rpx rgba(0, 0, 0, 0.15);
  overflow: hidden;
  flex-shrink: 0;
}

.user-avatar image {
  width: 100%;
  height: 100%;
}

.user-details {
  flex: 1;
  min-width: 0;
  margin-left: 16rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
  gap: 6rpx;
  box-sizing: border-box;
}

.user-name-container {
  display: flex;
  align-items: center;
  gap: 12rpx;
  min-width: 0;
}

.user-name {
  flex: 1;
  min-width: 0;
  display: block;
  font-size: 36rpx;
  font-weight: 700;
  line-height: 1.3;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.go-profile-icon {
  flex-shrink: 0;
  font-size: 36rpx;
  opacity: 0.7;
}

.user-uid {
  font-size: 22rpx;
  opacity: 0.8;
  line-height: 1.4;
}

.user-status {
  display: block;
  font-size: 24rpx;
  opacity: 0.9;
  line-height: 1.5;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.title-display-inline {
  width: 100%;
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 8rpx;
}

.title-label-inline {
  font-size: 22rpx;
  opacity: 0.8;
  font-weight: 500;
  white-space: nowrap;
}

.current-titles-inline {
  flex: 1;
  min-width: 0;
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 8rpx;
}

.title-tag-inline {
  font-size: 20rpx;
  color: #0ea5e9;
  background: rgba(255, 255, 255, 0.3);
  padding: 4rpx 10rpx;
  border-radius: 16rpx;
  white-space: nowrap;
  backdrop-filter: blur(4rpx);
}

.achievement-tag-inline {
  font-size: 20rpx;
  color: #fbbf24;
  background: rgba(255, 255, 255, 0.3);
  padding: 4rpx 10rpx;
  border-radius: 16rpx;
  white-space: nowrap;
  backdrop-filter: blur(4rpx);
}

.no-title-inline {
  font-size: 20rpx;
  opacity: 0.7;
  font-style: italic;
}

.user-stats {
  position: relative;
  z-index: 1;
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 30rpx;
  background: #fff;
  padding: 36rpx;
  border-radius: 32rpx;
  box-shadow: 0 8rpx 30rpx rgba(0, 0, 0, 0.1);
}

.stat-item {
  text-align: center;
}

.stat-value {
  margin-bottom: 12rpx;
  font-size: 44rpx;
  font-weight: 700;
  background: linear-gradient(135deg, #0ea5e9 0%, #06b6d4 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.stat-label {
  font-size: 24rpx;
  color: #64748b;
}

.user-menu {
  margin: 30rpx 40rpx;
  background: #fff;
  border-radius: 32rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.06);
}

.menu-item {
  padding: 32rpx 40rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  border-bottom: 1rpx solid #f1f5f9;
  transition: background 0.2s;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-item:active {
  background: #f8fafc;
}

.menu-left {
  display: flex;
  align-items: center;
  flex: 1;
}

.menu-icon {
  width: 52rpx;
  margin-right: 28rpx;
  font-size: 44rpx;
}

.menu-label {
  font-size: 30rpx;
  color: #1e293b;
  font-weight: 500;
}

.menu-right {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.menu-badge {
  font-size: 24rpx;
  color: #ef4444;
  padding: 6rpx 16rpx;
  background: #fee2e2;
  border-radius: 20rpx;
}

.menu-badge.signed {
  color: #10b981;
  background: #d1fae5;
}

.menu-arrow {
  color: #cbd5e1;
  font-size: 36rpx;
}
